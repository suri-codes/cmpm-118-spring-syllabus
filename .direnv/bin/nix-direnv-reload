#!/usr/bin/env bash
set -e
if [[ ! -d "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus/.envrc" "/Users/suri/dev/work/owenlab/cmpm118-spring-2026/syllabus/.direnv"/*.rc
